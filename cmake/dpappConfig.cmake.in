# dpappConfig.cmake - CMake package config for dpapp
@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# dpapp uses pthreads internally
find_dependency(Threads REQUIRED)

# Set include directory variable for compatibility
# PACKAGE_PREFIX_DIR is set by @PACKAGE_INIT@ and equals the install prefix
set(DPAPP_INCLUDE_DIR "${PACKAGE_PREFIX_DIR}/usr/include")

# Optional features at configure time (0 or 1); matches dpapp_config.h DPAPP_HAS_* semantics
set(DPAPP_HAS_SSL @DPAPP_SSL_ENABLE@)
set(DPAPP_HAS_LSQUIC @DPAPP_LSQUIC_ENABLE@)
set(DPAPP_HAS_LUA @DPAPP_LUA_ENABLE@)

# Imported targets are defined in this file (includes PUBLIC include directories)
# The INTERFACE_INCLUDE_DIRECTORIES property is already set correctly in Targets.cmake
# It uses _IMPORT_PREFIX/usr/include which will be resolved when find_package is called
include("${CMAKE_CURRENT_LIST_DIR}/dpappTargets.cmake")

check_required_components(dpapp)
