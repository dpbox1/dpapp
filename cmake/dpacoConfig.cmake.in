# dpacoConfig.cmake - CMake package config for dpaco
@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# Set include directory variable for compatibility
# PACKAGE_PREFIX_DIR is set by @PACKAGE_INIT@ and equals the install prefix
set(DPACO_INCLUDE_DIR "${PACKAGE_PREFIX_DIR}/usr/include")

# Imported targets are defined in this file (includes PUBLIC include directories)
# The INTERFACE_INCLUDE_DIRECTORIES property will contain _IMPORT_PREFIX/usr/include
include("${CMAKE_CURRENT_LIST_DIR}/dpacoTargets.cmake")

check_required_components(dpaco)
