# dpcwcConfig.cmake - CMake package config for dpcwc
@PACKAGE_INIT@

include(CMakeFindDependencyMacro)

# dpcwc builds on top of dpapp and dpaco
# Set search path for dependencies to the same location as dpcwc
# This ensures dependencies are found in the same prefix structure
get_filename_component(_dpcwc_cmake_dir "${CMAKE_CURRENT_LIST_DIR}" DIRECTORY)
list(APPEND CMAKE_PREFIX_PATH "${_dpcwc_cmake_dir}/dpaco")
list(APPEND CMAKE_PREFIX_PATH "${_dpcwc_cmake_dir}/dpapp")
find_dependency(dpaco REQUIRED PATHS "${_dpcwc_cmake_dir}/dpaco")
find_dependency(dpapp REQUIRED PATHS "${_dpcwc_cmake_dir}/dpapp")

# Set include directory variable for compatibility
# PACKAGE_PREFIX_DIR is set by @PACKAGE_INIT@ and equals the install prefix
set(DPCWC_INCLUDE_DIR "${PACKAGE_PREFIX_DIR}/usr/include")

# Imported targets (includes PUBLIC include directories from dpbox::dpcwc, dpbox::dpapp, dpbox::dpaco)
# The INTERFACE_INCLUDE_DIRECTORIES property will contain _IMPORT_PREFIX/usr/include
include("${CMAKE_CURRENT_LIST_DIR}/dpcwcTargets.cmake")

check_required_components(dpcwc)
