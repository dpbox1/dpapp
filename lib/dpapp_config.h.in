#pragma once

/**
 * @file dpapp_config.h
 * @brief dpapp library build configuration header
 *
 * This header file is automatically generated by CMake and contains
 * information about which optional features are enabled in this build
 * of the dpapp library.
 *
 * Third-party code can include this header to check for feature availability
 * at compile time, and also use the runtime detection functions provided
 * by the library.
 */

#ifdef __cplusplus
extern "C" {
#endif

/* Compile-time feature detection macros */
#define DPAPP_SSL_ENABLE @DPAPP_SSL_ENABLE@
#define DPAPP_LSQUIC_ENABLE @DPAPP_LSQUIC_ENABLE@
#define DPAPP_CWC_ENABLE @DPAPP_CWC_ENABLE@
#define DPAPP_CPP_ENABLE @DPAPP_CPP_ENABLE@
#define DPAPP_LUA_ENABLE @DPAPP_LUA_ENABLE@

/* Project version macros */
#define DPAPP_VERSION_MAJOR @DPAPP_VERSION_MAJOR@
#define DPAPP_VERSION_MINOR @DPAPP_VERSION_MINOR@
#define DPAPP_VERSION "dpapp-v@DPAPP_VERSION_MAJOR@.@DPAPP_VERSION_MINOR@"

/* Convenience macros for compile-time feature checks */

/**
 * @def DPAPP_HAS_SSL
 * @brief Compile-time check for SSL/TLS support
 *
 * This macro is defined to 1 if SSL support is available, 0 otherwise.
 * Use it in #if preprocessor directives for conditional compilation.
 *
 * Example:
 * @code
 * #if DPAPP_HAS_SSL
 *     // SSL-specific code
 * #endif
 * @endcode
 */
#define DPAPP_HAS_SSL DPAPP_SSL_ENABLE

/**
 * @def DPAPP_HAS_LSQUIC
 * @brief Compile-time check for QUIC/HTTP3 support
 *
 * This macro is defined to 1 if lsquic support is available, 0 otherwise.
 * Use it in #if preprocessor directives for conditional compilation.
 *
 * Example:
 * @code
 * #if DPAPP_HAS_LSQUIC
 *     // QUIC-specific code
 * #endif
 * @endcode
 */
#define DPAPP_HAS_LSQUIC DPAPP_LSQUIC_ENABLE

/**
 * @def DPAPP_HAS_CWC
 * @brief Compile-time check for CWC (C with coroutines) support in dpapp_bin
 *
 * This macro is defined to 1 if CWC mode is available in dpapp_bin, 0 otherwise.
 * Use it in #if preprocessor directives for conditional compilation.
 *
 * Example:
 * @code
 * #if DPAPP_HAS_CWC
 *     // CWC-specific code
 * #endif
 * @endcode
 */
#define DPAPP_HAS_CWC DPAPP_CWC_ENABLE

/**
 * @def DPAPP_HAS_CPP
 * @brief Compile-time check for C++ coroutines support in dpapp_bin
 *
 * This macro is defined to 1 if C++ mode is available in dpapp_bin, 0 otherwise.
 * Use it in #if preprocessor directives for conditional compilation.
 *
 * Example:
 * @code
 * #if DPAPP_HAS_CPP
 *     // C++ coroutines-specific code
 * #endif
 * @endcode
 */

 #if DPAPP_CPP_ENABLE && defined(__cplusplus)
 # define DPAPP_HAS_CPP 1
 #else
 # define DPAPP_HAS_CPP 0
 #endif

/**
 * @def DPAPP_HAS_LUA
 * @brief Compile-time check for dplua / Lua tooling in this build
 *
 * Defined to 1 when CMake was configured with `DPAPP_WITH_LUA=ON`, 0 otherwise.
 * Matches `DPAPP_LUA_ENABLE` in `dpapp_config.h`.
 */
#define DPAPP_HAS_LUA DPAPP_LUA_ENABLE

/* Runtime feature detection functions are declared in:
 * - dpssl_enable() in dpssl.h
 * - dpqic_enable() in dpqic.h
 */

#define DPAPP_VERSION_DETAIL "dpapp-v@DPAPP_VERSION_MAJOR@.@DPAPP_VERSION_MINOR@ (ssl:@DPAPP_SSL_ENABLE@ lsquic:@DPAPP_LSQUIC_ENABLE@ cwc:@DPAPP_CWC_ENABLE@ cpp:@DPAPP_CPP_ENABLE@ lua:@DPAPP_LUA_ENABLE@)"

#ifdef __cplusplus
}
#endif
